---
import Container from "./ui/Container.astro";
import partnersData from "../data/partners.json";
import { Image } from "astro:assets";
import { getPartnerLogos } from "../utils/partnersLoader";

const {
  sponsorsTitle,
  supportTitle,
  sponsors = [],
  support = [],
} = partnersData;
const { sponsorsMap = {}, supportMap = {} } = getPartnerLogos();

const normalize = (s: string) => s.toLowerCase().replace(/[^a-z0-9]/g, "");

// Map and sort sponsors based on partners.json
const sponsorsData = sponsors
  .map((name) => {
    const normalizedName = normalize(name);
    const key = Object.keys(sponsorsMap).find((k) => {
      const normalizedKey = normalize(k.split("/").pop()?.split(".")[0] || "");
      return (
        normalizedKey.includes(normalizedName) ||
        normalizedName.includes(normalizedKey)
      );
    });
    return key ? sponsorsMap[key] : null;
  })
  .filter(Boolean);

// Map and sort support brands based on partners.json
const supportData = support
  .map((name) => {
    const normalizedName = normalize(name);
    const key = Object.keys(supportMap).find((k) => {
      const normalizedKey = normalize(k.split("/").pop()?.split(".")[0] || "");
      return (
        normalizedKey.includes(normalizedName) ||
        normalizedName.includes(normalizedKey)
      );
    });
    return key ? supportMap[key] : null;
  })
  .filter(Boolean);
---

<section id="patrocinio" class="py-4 md:py-8 bg-transparent relative">
  <div class="px-4 md:px-12 max-w-400 mx-auto w-full">
    <div
      class="glass p-4 md:p-16 rounded-2xl md:rounded-[3.5rem] shadow-premium border border-primary/10 bg-white/5 backdrop-blur-md w-full"
    >
      <div class="mb-6 md:mb-10">
        <h4
          class="text-center text-xl md:text-3xl font-black font-outfit text-[#5A4A4A] mb-8 md:mb-14"
        >
          {sponsorsTitle}
        </h4>
        <div
          class="flex flex-wrap lg:flex-nowrap justify-center items-center gap-4 md:gap-16 w-full"
        >
          {
            sponsorsData.map((logo) => (
              <div class="transition-transform duration-500 hover:scale-110 cursor-pointer flex items-center justify-center shrink-0">
                <Image
                  src={logo}
                  alt="Patrocinador"
                  class="h-12 md:h-24 w-auto max-w-[150px] md:max-w-[280px] object-contain"
                />
              </div>
            ))
          }
        </div>
      </div>

      <div>
        <h4
          class="text-center text-xl md:text-3xl font-black font-outfit text-[#5A4A4A] mb-6 md:mb-12"
        >
          {supportTitle}
        </h4>
        <div
          class="flex flex-wrap lg:flex-nowrap justify-center items-center gap-3 md:gap-10 w-full"
        >
          {
            supportData.map((logo) => (
              <div class="transition-transform duration-500 hover:scale-105 cursor-pointer flex items-center justify-center shrink-0">
                <Image
                  src={logo}
                  alt="Apoiador"
                  class="h-10 md:h-16 w-auto max-w-[100px] md:max-w-[170px] object-contain"
                />
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
