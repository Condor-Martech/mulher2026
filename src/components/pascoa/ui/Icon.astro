---
interface Props {
  name: string;
  width?: string | number;
  height?: string | number;
  class?: string;
  color?: string;
}

const {
  name,
  width = 18,
  height = 18,
  class: className,
  color = "currentColor",
} = Astro.props;

// Use dynamic import to get the SVG content or handle it via image if preferred
// But for performance and styling (fill="currentColor"), raw SVGs or a map is better.
// Given Astro's capabilities, we can import them and use as components or raw source.

import fs from "node:fs";
import path from "node:path";

const iconPath = path.join(
  process.cwd(),
  "public",
  "assets",
  "pascoa",
  "icons",
  `${name}.svg`,
);
let rawSvg = "";
try {
  rawSvg = fs.readFileSync(iconPath, "utf-8");
} catch (e) {
  console.error(`Icon ${name} not found at ${iconPath}`);
}

// Clean up the SVG a bit if necessary or just inject it
// We assume icons are cleaned up and have currentColor where needed
---

<div
  class={className}
  style={`width: ${typeof width === "number" ? width + "px" : width}; height: ${typeof height === "number" ? height + "px" : height}; color: ${color}; display: flex; align-items: center; justify-content: center;`}
  set:html={rawSvg}
/>

<style>
  div :global(svg) {
    width: 100%;
    height: 100%;
  }
</style>
