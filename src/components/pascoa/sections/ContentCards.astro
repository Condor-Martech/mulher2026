---
import Badge from "../ui/Badge.astro";
interface Card {
  title: string;
  bgPlaceholder: string;
  image: string;
  link?: string;
}

interface Props {
  data: Card[];
}

const { data } = Astro.props;
---

<section
  class="relative w-full max-w-7xl mx-auto py-2 md:py-8 z-20 overflow-hidden"
>
  {/* Mobile Swipe Badge */}
  <div class="flex justify-center mb-6 md:hidden">
    <Badge
      label="Deslize para ver mais"
      class="bg-white text-brand-red border border-brand-red/10 animate-swipe-indicator"
    />
  </div>

  <div
    class="flex overflow-x-auto snap-x snap-mandatory gap-4 md:grid md:grid-cols-3 md:gap-8 px-4 pb-4 md:pb-0 hide-scrollbar -mx-4 md:mx-0"
  >
    {
      data.map((card, idx) => (
        <a
          href={card.link}
          target={card.link?.startsWith("http") ? "_blank" : undefined}
          rel={
            card.link?.startsWith("http") ? "noopener noreferrer" : undefined
          }
          class="card-item relative aspect-3/4 overflow-hidden rounded-3xl group cursor-pointer shadow-xl transition-all duration-700 ease-out min-w-[50%] md:min-w-0 snap-center md:snap-align-none block no-underline"
        >
          <div class={`absolute inset-0 ${card.bgPlaceholder}`} />

          {card.image && (
            <img
              src={card.image}
              alt={card.title}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 pointer-events-none"
            />
          )}

          {/* Overlay Gradient for readability */}
          <div class="absolute inset-0 bg-linear-to-t from-black/60 via-transparent to-transparent opacity-60 transition-opacity duration-300 group-hover:opacity-80 pointer-events-none" />

          {/* Title Text */}
          <div class="absolute inset-x-0 bottom-0 p-8 pointer-events-none">
            <h3 class="text-xl md:text-[1.75rem] font-bold text-white whitespace-pre-line leading-tight text-center drop-shadow-md">
              {card.title}
            </h3>
          </div>
        </a>
      ))
    }

    {
      /* Extra spacer for mobile so the last card isn't flush with the right edge completely */
    }
    <div class="min-w-[4%] md:hidden snap-end"></div>
  </div>
</section>

<style>
  .card-item {
    will-change: transform, opacity;
  }
  @keyframes swipe-indicator {
    0% {
      transform: translateX(0);
      opacity: 1;
    }
    40% {
      transform: translateX(10px);
      opacity: 0.8;
    }
    80% {
      transform: translateX(0);
      opacity: 1;
    }
    100% {
      transform: translateX(0);
      opacity: 1;
    }
  }
  .animate-swipe-indicator {
    animation: swipe-indicator 2.5s ease-in-out infinite;
  }
</style>
