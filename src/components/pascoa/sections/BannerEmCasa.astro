---
interface Props {
  data: {
    badgeImg: string;
    text1: string;
    text2: string;
    bgImg: string;
  };
}

const { data } = Astro.props;
---

<section
  id="condoremcasa"
  class="relative w-[95%] md:w-[90%] lg:w-[80%] xl:w-[70vw] max-w-7xl mx-auto py-4 md:py-8 z-20"
>
  <a
    href="https://www.condor.com.br/"
    target="_blank"
    rel="noopener noreferrer"
    class="banner-content relative w-full rounded-4xl lg:rounded-[2.5rem] overflow-hidden flex flex-col md:flex-row items-center justify-center py-10 lg:py-10 px-6 md:px-8 lg:px-16 gap-6 md:gap-8 lg:gap-16 cursor-pointer block no-underline"
  >
    {/* Background dark blue base with the texture image */}
    <div class="absolute inset-0 bg-brand-blue-dark -z-20"></div>
    <div
      class="absolute inset-0 -z-10 opacity-30 bg-cover bg-center mix-blend-overlay"
      style={`background-image: url('${data.bgImg}')`}
    >
    </div>

    <div class="shrink-0 w-44 md:w-56 lg:w-72">
      <img src={data.badgeImg} alt="Condor em Casa" class="w-full h-auto" />
    </div>

    <div
      class="flex flex-col text-center md:text-left justify-center font-['Montserrat']"
    >
      <h2
        class="text-xl md:text-2xl lg:text-[2.4rem] font-bold text-white leading-[1.1] uppercase tracking-[-0.02em]"
      >
        {data.text1}
        <br class="hidden sm:block" />
        <span class="text-[#ffb600] font-black tracking-[-0.05em]"
          >{data.text2}</span
        >
      </h2>
    </div>
  </a>
</section>

<style>
  .banner-content {
    will-change: transform, opacity;
  }
</style>
