---
interface Props {
  data: {
    thumbnailImg: string;
    youtubeId: string;
  };
}

const { data } = Astro.props;
---

<section
  class="relative w-full max-w-6xl mx-auto px-2 md:px-4 py-4 md:py-8 z-20"
>
  <div
    id="video-container"
    class="relative aspect-video w-full rounded-3xl md:rounded-[3.5rem] overflow-hidden sharp-glass shadow-[0_40px_80px_-15px_rgba(62,12,3,0.5)] group cursor-pointer transition-transform duration-300 ease-out"
    data-video-id={data.youtubeId}
  >
    {/* Thumbnail & UI (Visible by default) */}
    <div
      id="video-overlay"
      class="absolute inset-0 z-10 transition-opacity duration-500"
    >
      {/* Fallback Image */}
      <div
        data-s3-bg="video.thumbnailImg"
        class="absolute inset-0 bg-cover bg-center bg-no-repeat transition-transform duration-700 group-hover:scale-105"
        style={`background-image: url('${data.thumbnailImg}')`}
      >
      </div>

      {/* Dark Overlay */}
      <div
        class="absolute inset-0 bg-black/20 group-hover:bg-black/40 transition-colors duration-500"
      >
      </div>

      {/* Play Button */}
      <div class="absolute inset-0 flex items-center justify-center">
        <div
          class="play-button w-16 h-16 md:w-32 md:h-32 bg-white/20 backdrop-blur-md rounded-full flex items-center justify-center border border-white/40 shadow-[0_0_40px_rgba(255,255,255,0.4)] transition-all duration-300 group-hover:scale-110 group-hover:bg-white/30 active:scale-95"
        >
          <div
            class="ml-1.5 md:ml-3 w-0 h-0 border-y-10 border-l-16 md:border-y-18 md:border-l-30"
            style="border-top-color: transparent; border-bottom-color: transparent; border-left-color: white;"
          >
          </div>
        </div>
      </div>
    </div>

    {/* YouTube Player Container (Loaded on click) */}
    <div
      id="youtube-player"
      class="absolute inset-0 bg-black opacity-0 pointer-events-none transition-opacity duration-500"
    >
    </div>
  </div>
</section>

<script>
  const videoContainer = document.getElementById("video-container");
  const videoOverlay = document.getElementById("video-overlay");
  const playerDiv = document.getElementById("youtube-player");

  if (videoContainer && videoOverlay && playerDiv) {
    videoContainer.addEventListener("click", () => {
      const videoId = videoContainer.getAttribute("data-video-id");
      if (!videoId) return;

      // Swap UI
      videoOverlay.classList.add("opacity-0", "pointer-events-none");
      playerDiv.classList.remove("opacity-0", "pointer-events-none");
      playerDiv.classList.add("opacity-100", "pointer-events-auto");

      // Inject Iframe
      playerDiv.innerHTML = `
        <iframe 
          width="100%" 
          height="100%" 
          src="https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0" 
          title="YouTube video player" 
          frameborder="0" 
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
          allowfullscreen
        ></iframe>
      `;
    });
  }
</script>
<style>
  #video-container {
    will-change: transform;
  }
</style>
