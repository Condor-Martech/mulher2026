---
import MenuIcon from "./icons/Menu.astro";
import CloseIcon from "./icons/Close.astro";
import navbarData from "../data/navbar.json";

const { links } = navbarData;
---

<header
  class="fixed top-8 left-0 right-0 z-50 flex justify-center md:px-6 pointer-events-none"
>
  <div class="container mx-auto flex justify-start pointer-events-auto">
    <!-- Desktop Nav -->
    <nav
      class="hidden lg:flex glass-white px-10 py-4 rounded-full items-center space-x-10 text-[12px] font-black uppercase tracking-[0.2em] text-accent shadow-2xl border border-white/20 group"
    >
      {
        links.map((link) => (
          <a
            href={link.href}
            target={link.target}
            class="hover:text-primary transition-all py-1 border-b-2 border-transparent hover:border-primary transform hover:-translate-y-0.5"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <!-- Mobile Nav Toggle -->
    <div class="lg:hidden w-full flex justify-end items-center">
      <button
        id="mobile-menu-toggle"
        class="glass-dark p-3 rounded-2xl border border-white/20 shadow-xl text-white active:scale-95 transition-transform"
        aria-label="Toggle Menu"
      >
        <MenuIcon class="w-6 h-6" />
      </button>
    </div>
  </div>

  <!-- Mobile Menu Overlay -->
  <div
    id="mobile-menu"
    class="fixed inset-0 bg-[#FFF1F2] z-60 flex flex-col items-center justify-center opacity-0 pointer-events-none transition-all duration-500 lg:hidden"
  >
    <!-- Background script branding -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none opacity-5">
      <span
        class="absolute -top-10 -left-10 text-[20rem] font-script text-primary rotate-12"
        >Mês</span
      >
      <span
        class="absolute -bottom-20 -right-20 text-[25rem] font-script text-primary -rotate-12"
        >Mulher</span
      >
    </div>

    <button
      id="close-menu"
      class="absolute top-8 right-8 p-3 rounded-2xl bg-primary text-white shadow-lg active:scale-95 transition-transform"
      aria-label="Close Menu"
    >
      <CloseIcon class="w-8 h-8" />
    </button>

    <div class="flex flex-col items-center space-y-10 relative z-10">
      {
        links.map((link) => (
          <a
            href={link.href}
            target={link.target}
            class="mobile-nav-link text-xl sm:text-2xl font-black uppercase tracking-widest sm:tracking-[0.2em] text-[#E95D79] hover:scale-105 active:scale-95 transition-transform text-center px-4"
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <div class="absolute bottom-12 text-center opacity-40">
      <p
        class="text-[10px] uppercase font-black tracking-[0.3em] text-[#5A4A4A]"
      >
        Condor com você
      </p>
    </div>
  </div>
</header>

<script>
  import { initNavbarHandler } from "../utils/navbarHandler";
  initNavbarHandler();
</script>

<style>
  .mobile-nav-link {
    @apply transition-all duration-300 hover:scale-110 active:scale-95;
  }
</style>
