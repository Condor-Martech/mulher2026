---
import Waves from "./icons/Waves.astro";
import Container from "./ui/Container.astro";
import { Image } from "astro:assets";
import condorLogo from "../assets/condor-logo.png";
import Facebook from "./icons/Facebook.astro";
import Instagram from "./icons/Instagram.astro";
import YouTube from "./icons/YouTube.astro";
import X from "./icons/X.astro";
import TikTok from "./icons/TikTok.astro";
import LinkedIn from "./icons/LinkedIn.astro";
import footerData from "../data/footer.json";
import settings from "../data/settings.json";

const { copyright, socialLinks, currentYear } = footerData;
const { galeriaCta } = settings;
---

<footer class="relative pt-8 mt-2 md:pt-12 md:mt-12 overflow-hidden">
  <!-- Organic Pastel Background Layer -->
  <div
    class="absolute bottom-0 left-0 right-0 top-11 bg-linear-to-b from-primary/15 to-white overflow-hidden"
    aria-hidden="true"
  >
    <Waves />
  </div>

  <!-- Primary Top Accent Bar -->
  <div
    class="absolute top-11 left-0 right-0 h-[2px] bg-linear-to-r from-transparent via-primary/60 to-transparent z-10"
    aria-hidden="true"
  >
  </div>

  <!-- Content -->
  <Container
    className="relative z-20 py-4 md:py-10 flex flex-col lg:flex-row items-center justify-between gap-6 lg:gap-5"
  >
    <!-- Logo -->
    <a
      href={import.meta.env.BASE_URL}
      class="inline-flex items-center transition-transform duration-300 hover:scale-105 shrink-0"
      aria-label="Ir para o topo"
    >
      <Image
        src={condorLogo}
        alt="Logo Condor"
        height={40}
        class="h-10 md:h-8 mt-4 w-auto object-contain"
      />
    </a>

    <!-- Gallery Link & Copyright -->
    <div class="flex-1 flex flex-col items-center gap-2">
      {
        galeriaCta && (
          <a
            href={galeriaCta.url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-primary font-bold text-xs uppercase tracking-widest hover:underline decoration-2 underline-offset-4 transition-all"
          >
            {galeriaCta.label}
          </a>
        )
      }
      <p
        class="text-center font-bold text-[10px] tracking-[0.2em] uppercase text-primary/80 min-w-[180px]"
      >
        &copy; {currentYear}
        {copyright}
      </p>
    </div>

    <!-- Social Icons -->
    <div
      class="flex items-center flex-nowrap gap-2 md:gap-2.5 shrink-0"
      role="list"
      aria-label="Redes sociais"
    >
      {
        socialLinks.map((link) => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={link.name}
            class="flex items-center justify-center w-8 h-8 md:w-10 md:h-10 rounded-full text-white border border-white/20 transition-all duration-300 hover:scale-115 hover:-translate-y-1 hover:brightness-110 shadow-lg"
            style={`background: ${link.bg}; box-shadow: 0 4px 12px ${link.shadow};`}
            role="listitem"
          >
            {link.icon === "facebook" && <Facebook />}
            {link.icon === "instagram" && <Instagram />}
            {link.icon === "youtube" && <YouTube />}
            {link.icon === "x" && <X class="w-5 h-5" />}
            {link.icon === "tiktok" && <TikTok class="w-5 h-5" />}
            {link.icon === "linkedin" && <LinkedIn class="w-5 h-5" />}
          </a>
        ))
      }
    </div>
  </Container>
</footer>
