---
import Container from "./ui/Container.astro";
import experienceData from "../data/experience.json";

const { text, cta } = experienceData;
---

<section class="py-2 md:py-10 bg-transparent relative overflow-hidden">
  <Container className="max-w-4xl relative z-10 px-4">
    <div
      class="glass-white p-8 md:p-16 rounded-[2rem] md:rounded-[4rem] shadow-glass border border-white/40 text-center"
    >
      <div class="space-y-4 md:space-y-8">
        <p
          class="text-lg md:text-3xl font-bold text-accent leading-relaxed tracking-tight"
          set:html={text}
        />
        <div
          class="inline-block px-8 py-3 md:px-10 md:py-4 bg-primary rounded-full shadow-lg shadow-primary/30 transform hover:scale-105 active:scale-95 transition-all duration-300"
        >
          <p
            class="text-sm md:text-xl font-bold text-white uppercase tracking-widest"
          >
            {cta}
          </p>
        </div>
      </div>
    </div>
  </Container>
</section>
