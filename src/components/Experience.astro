---
import Container from "./ui/Container.astro";
import experienceData from "../data/experience.json";

const { text, cta } = experienceData;
---

<section class="py-12 md:py-20 bg-transparent relative overflow-hidden">
  {/* Bubbles decoration */}
  <div
    class="absolute top-10 left-10 w-64 h-64 glass rounded-full opacity-15 z-0"
  >
  </div>
  <div
    class="absolute bottom-10 right-10 w-96 h-96 glass rounded-full opacity-10 z-0"
  >
  </div>

  <Container className="max-w-4xl relative z-10">
    <div
      class="glass-white p-6 md:p-16 rounded-[2rem] md:rounded-[4rem] shadow-glass border border-white/40 text-center"
    >
      <div class="space-y-6 md:space-y-8">
        <p
          class="text-xl md:text-3xl font-bold text-accent leading-relaxed tracking-tight"
          set:html={text}
        />
        <div
          class="inline-block px-10 py-4 bg-primary rounded-full shadow-lg shadow-primary/30 transform hover:scale-105 active:scale-95 transition-all duration-300"
        >
          <p
            class="text-base md:text-xl font-bold text-white uppercase tracking-widest"
          >
            {cta}
          </p>
        </div>
      </div>
    </div>
  </Container>
</section>
