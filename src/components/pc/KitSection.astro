---

---

<section
  id="kit"
  class="pt-0 pb-8 md:pt-0 md:pb-20 relative overflow-hidden z-20 w-full flex justify-center"
>
  <!-- Dark Blue Background Shape -->
  <div class="absolute w-[85%] md:w-[75%]"></div>

  <div
    class="container mx-auto px-4 relative z-10 max-w-[1440px] flex justify-center"
  >
    <div class="flex flex-col lg:flex-row items-center justify-between w-full">
      <!-- Left Content (Cyan Banner) -->
      <div
        class="w-full lg:w-[85%] flex justify-center lg:justify-end lg:-mr-16 z-10 relative"
      >
        <img
          src="/public/assets/pc/Premios 1.png"
          alt="SERÃO DISTRIBUÍDOS 1.900 KITS"
          class="w-full max-w-[1174px] h-auto object-contain drop-shadow-[0_15px_30px_rgba(0,0,0,0.3)]"
        />
      </div>

      <!-- Right Content (Images with pop-out depth) -->
      <div
        class="w-full lg:w-[40%] relative z-30 flex justify-center lg:justify-start mt-8 lg:mt-0 lg:-ml-28"
      >
        <div
          class="relative w-full max-w-[360px] flex items-center justify-center lg:justify-start"
        >
          <!-- Camisa Image (Back Layer) -->
          <div
            class="relative z-10 transform hover:-translate-y-2 hover:rotate-1 transition-all duration-500 translate-x-4 md:translate-x-8 lg:translate-x-12"
          >
            <img
              src="/public/assets/pc/Camisa 1.png"
              alt="Camiseta"
              class="w-[200px] md:w-[260px] lg:w-[300px] max-w-none h-auto drop-shadow-[0_20px_40px_rgba(0,0,0,0.4)]"
            />
          </div>

          <!-- Sacochila Image (Front Layer, Overlapping) -->
          <div
            class="absolute z-20 bottom-[-20px] left-0 md:bottom-[-30px] md:left-[10px] lg:bottom-[-40px] lg:left-[20px] transform hover:-translate-y-2 hover:-rotate-1 transition-all duration-500"
          >
            <img
              src="/public/assets/pc/Sacochila 1.png"
              alt="Sacochila"
              class="w-[120px] md:w-[160px] lg:w-[200px] max-w-none h-auto drop-shadow-[0_20px_40px_rgba(0,0,0,0.5)]"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
