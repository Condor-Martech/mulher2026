---

---

<section
  id="detalhes"
  class="pb-4 overflow-hidden relative"
  style="background-color: #4EC5F1;"
>
  <div class="container mx-auto px-4">
    <!-- Comemore Banner using Asset -->
    <div class="max-w-4xl mx-auto mb-16 px-4 flex justify-center mt-20">
      <img
        src="/public/assets/pc/Comemore 333 1.png"
        alt="Comemore os 333 anos de Curitiba com saúde e bem-estar!"
        class="w-full max-w-[900px] h-auto hover:scale-105 transition-transform drop-shadow-2xl"
      />
    </div>

    <!-- Trajeto Section Area (Includes dark geometric background wrapper) -->
    <div class="relative w-full max-w-6xl mx-auto mt-18">
      <!-- Dark Geometric Background Element -->
      <div
        class="absolute inset-0 bg-blue-950/40 -skew-y-2 transform origin-left rounded-[60px] md:rounded-[100px] -z-10 shadow-2xl border border-white/5"
      >
      </div>

      <div class="relative py-6 px-4 md:px-12">
        <h3
          class="text-white text-4 xl md:text-5xl lg:text-6xl font-black uppercase text-center mb-8 tracking-tighter drop-shadow-md"
        >
          TRAJETO
        </h3>

        <!-- Map Card Container -->
        <div
          class="w-full max-w-5xl mx-auto bg-white rounded-[40px] md:rounded-[60px] p-3 md:p-6 shadow-[0_30px_60px_rgba(0,0,0,0.6)] transform md:-rotate-1"
        >
          <!-- Inner card border for premium feel -->
          <div
            class="rounded-[30px] md:rounded-[48px] overflow-hidden border-4 border-blue-50/50 relative shadow-inner"
          >
            <img
              src="/public/assets/pc/mapa 1.png"
              alt="Mapa do Trajeto"
              class="w-full h-auto object-cover hover:scale-[1.02] transition-transform duration-700"
            />
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Decorative separator bottom -->
  <div class="w-full border-t-2 border-dashed border-white mt-10 mb-4"></div>
</section>
