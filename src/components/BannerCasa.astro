---
import { Image } from "astro:assets";
import condorCasaImg from "../assets/condor em casa.png";
import condorCasaMobileImg from "../assets/condor em casa - mobile.png";
import ArrowRight from "./icons/ArrowRight.astro";
import bannerCasaData from "../data/banner-casa.json";

const { alt, ctaLabel, ctaLink } = bannerCasaData;
---

<section class="py-1 md:py-4">
  <div class="container mx-auto px-4 md:px-6">
    <div class="max-w-full md:max-w-[90%] mx-auto relative group">
      <!-- Glass Frame Background -->
      <div
        class="absolute -inset-2 md:-inset-8 glass rounded-3xl md:rounded-[3rem] opacity-50 -z-10 blur-xl group-hover:opacity-80 transition-opacity duration-700"
      >
      </div>

      <a
        href={ctaLink}
        target="_blank"
        rel="noopener noreferrer"
        class="block cursor-pointer transition-transform duration-700 hover:scale-[1.02] hover:-translate-y-1"
      >
        <!-- Desktop Banner -->
        <Image
          src={condorCasaImg}
          alt={alt}
          width={1000}
          height={600}
          class="hidden md:block w-full h-auto"
        />
        <!-- Mobile Banner -->
        <Image
          src={condorCasaMobileImg}
          alt={alt}
          width={500}
          height={500}
          class="md:hidden w-full h-auto"
        />
      </a>
    </div>
  </div>
</section>
