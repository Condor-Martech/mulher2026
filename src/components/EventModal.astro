---
// src/components/EventModal.astro
import CloseIcon from "./icons/CloseIcon.astro";
import EventRegistrationForm from "./EventRegistrationForm.astro";
---

<dialog
  id="event-modal"
  class="backdrop:bg-black/60 backdrop:backdrop-blur-sm bg-transparent w-full h-full max-w-none max-h-none m-0 p-0 md:h-auto md:max-w-[470px] md:m-auto md:p-4 open:animate-in open:fade-in open:zoom-in duration-300"
>
  <div
    class="bg-[#FFF6F6] rounded-none md:rounded-4xl min-h-full md:min-h-0 overflow-hidden shadow-none md:shadow-[0_20px_50px_rgba(235,93,121,0.3)] relative flex flex-col"
  >
    {/* Header Section */}
    <div class="bg-primary/5 p-5 md:p-8 border-b border-primary/10 relative">
      <button
        id="close-modal-btn"
        type="button"
        class="absolute top-6 right-6 text-primary hover:bg-primary/10 p-2 rounded-full transition-colors focus:outline-none focus:ring-2 focus:ring-primary/50"
        aria-label="Fechar modal"
      >
        <CloseIcon />
      </button>

      <h3 class="text-3xl font-black text-primary mb-2">Inscreva-se</h3>
      <p id="modal-event-title" class="text-lg text-[#6D5D5D] font-medium">
        Tema: Carregando...
      </p>
      <p
        id="modal-event-date"
        class="text-sm font-bold text-[#5A4A4A] mt-1 space-x-2"
      >
        Data: Carregando...
      </p>
    </div>

    {/* Form Section */}
    <div class="p-4 md:p-10 grow">
      <EventRegistrationForm />
    </div>
  </div>
</dialog>

<script>
  import { initModalHandler } from "../utils/modalHandler";
  initModalHandler();
</script>

<style>
  dialog::backdrop {
    background-color: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
  }
</style>
